# Локальная разработка — скопировать в .env.local
# cp .env.local.example .env.local

# PostgreSQL (docker-compose)
DATABASE_URL=postgres://bakebay:bakebay@localhost:5432/bakebay?sslmode=disable

# MinIO (docker-compose) — S3-совместимое хранилище
S3_ENDPOINT=localhost
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=bakebay
S3_PORT=9000
S3_USE_SSL=false

# Auth
JWT_SECRET_KEY=local-dev-jwt-secret-change-me
SECRET=10
